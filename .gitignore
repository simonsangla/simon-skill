# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# Local Claude config that should never be committed
.claude/settings.local.json
# Active hook registration — gitignored so cloning the repo does not silently
# enable hooks before review. The committed template is .claude/settings.json.example.
.claude/settings.json
# Runtime lock for the scheduled-tasks MCP — process artifact, never committed.
.claude/scheduled_tasks.lock

# Secrets (defense in depth — should never exist here, but blocking just in case)
.env
.env.*
!.env.example

# Node (in case anyone adds JS tooling later)
node_modules/
npm-debug.log*

# Python (in case scripts use uv/venv)
.venv/
__pycache__/
*.pyc

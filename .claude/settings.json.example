{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_install": "Rename this file to .claude/settings.json to activate. Activation is a separate (user-approved) step because registering PreToolUse/PostToolUse hooks counts as self-modifying agent configuration.",
  "_comment_paths": "Absolute paths needed so the global check-hook-script-paths.sh validator (~/.claude/hooks/) can stat them — it does not expand $CLAUDE_PROJECT_DIR. If you have this repo at a different path, edit both commands accordingly.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/simonsangla/projects/simon-productivity/.claude/hooks/check-template-sync.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/simonsangla/projects/simon-productivity/.claude/hooks/block-git-add-all.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
